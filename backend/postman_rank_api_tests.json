    {
      "name": "Rank issues with invalid request body",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"foo\": \"bar\"\n}"
        },
        "url": {
          "raw": "http://localhost:3232/api/rank",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3232",
          "path": ["api", "rank"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 400', function () {", 
              "    pm.response.to.have.status(400);", 
              "});", 
              "pm.test('Error message is returned', function () {", 
              "    var jsonData = pm.response.json();", 
              "    pm.expect(jsonData).to.have.property('error');", 
              "});"
            ],
